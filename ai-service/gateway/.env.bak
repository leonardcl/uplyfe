# Gateway settings
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8001

# Shared API key (must match Laravel's AI_SERVICE_KEY).
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
AI_SERVICE_KEY=w58CR8tjGhAK98LmhOB7TKya1JZ6Vcw30VB9aF-EqXY

# Ollama (used by exercise + recipe modules and by health-checkup).
# Set OLLAMA_MODEL to whatever `ollama list` shows on this machine.
# Common picks: gemma2:9b, gemma2:27b, gemma3:4b, llama3.1:8b, qwen2.5:7b.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:26b
OLLAMA_TIMEOUT_SECONDS=120

# Path to the existing health-checkup-extraction project (relative to gateway/)
HEALTH_CHECKUP_PATH=../health-checkup-extraction
