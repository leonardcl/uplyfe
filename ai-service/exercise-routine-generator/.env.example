# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=gemma4:26b
LLM_MODEL_SMALL=gemma4:26b
EMBED_MODEL=embeddinggemma
LLM_TIMEOUT_SECONDS=180

# --- ChromaDB ---
# Paths resolve relative to the project root (this directory). Both
# collections live in the same store.
CHROMA_DIR=./data/chroma
EXERCISE_COLLECTION=exercises
PDF_COLLECTION=pdf_books

# --- Retrieval ---
TOP_K_EXERCISE=20
TOP_K_PDF=5

# --- API ---
API_HOST=0.0.0.0
API_PORT=8002
