# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# --- Local config ---
# .env

# --- Generated data ---
data/chroma/        # ChromaDB on-disk store; rebuild with `make seed`
data/uploads/       # transient upload tempdir

# --- PDFs (privacy + bloat) ---
# All PDFs are excluded by default — anything sensitive or regenerable should
# stay out of git. The exceptions are anchor sample(s) in data/samples/ that we
# WANT in git for the demo CLI.
*.pdf
!data/samples/*.pdf

# --- Sample report folders ---
# samples/synthetic/  — generated by tools/generate_synthetic.py; *.pdf rule
#                       above keeps the PDFs out, but the .json expected files
#                       in samples/expected/ ARE tracked (ground truth).
# samples/private/    — your own real lab PDFs. Never committed.
# samples/online/     — anything scraped publicly. Treat as private by default.
samples/private/
samples/online/

# --- Test / lint caches ---
.coverage
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- OS noise ---
.DS_Store
